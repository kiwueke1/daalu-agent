# ──────────────────────────────────────────────────────────────────────────
# Daalu agent — configuration. Copy to `.env` and edit.
#   cp .env.example .env
# Every value here has a safe default for local single-node use; the ones
# you'll actually want to change are called out with ◀ CHANGE ME.
# ──────────────────────────────────────────────────────────────────────────

# ── Mode ───────────────────────────────────────────────────────────────────
# development | production. `development` enables /docs and friendlier logs.
ENVIRONMENT=development
LOG_LEVEL=INFO

# Single-tenant mode. When true the API skips all authentication and runs
# as one built-in local operator — this is what makes the laptop quickstart
# work with no login. NEVER set this true on a network-reachable host.
LOCAL_NO_AUTH=true

# Host address the docker-compose stack publishes its ports on. Loopback by
# default so a no-auth install is reachable only from this machine. Put Daalu
# behind an authenticating reverse proxy before changing this (e.g. 0.0.0.0 or
# a specific host IP). See docs/04-deployment.md §1.6.
BIND_ADDR=127.0.0.1

# Signs session JWTs / personal-access-tokens AND derives the at-rest key that
# encrypts stored credentials (kubeconfigs, SSH keys). `install.sh` generates a
# unique value here automatically; if you create .env by hand, replace this with
# `openssl rand -hex 32`. The app refuses to start with this placeholder when
# LOCAL_NO_AUTH=false or ENVIRONMENT=production.
SECRET_KEY=change-me-to-a-long-random-string   # ◀ CHANGE ME (install.sh does this for you)

# ── Datastores ───────────────────────────────────────────────────────────────
# Postgres (async driver) + Redis. The docker-compose file points these at the
# bundled containers; override if you bring your own.
DATABASE_URL=postgresql+asyncpg://daalu:daalu_password@postgres:5432/daalu_agent
# Same database, sync driver (psycopg2) — `daalu migrate` / Alembic need this.
# It's the DATABASE_URL above with the `+asyncpg` removed. Required: `daalu
# migrate` reads it straight from the environment and fails if it's unset.
DATABASE_SYNC_URL=postgresql://daalu:daalu_password@postgres:5432/daalu_agent
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Inference (this is the "sovereign" part) ────────────────────────────────
# The agent talks to ANY OpenAI-compatible endpoint. Point it at your own
# vLLM / Ollama / TGI server and NO prompt or code ever leaves your network.
#
# Example A — local Ollama on the host (default for the quickstart):
LLM_BASE_URL=http://host.docker.internal:11434/v1   # ◀ your inference endpoint
LLM_API_KEY=ollama                                  # any non-empty string for local servers
LLM_MODEL=qwen2.5:14b                               # ◀ a model you've pulled
LLM_MODEL_CLASSIFIER=qwen2.5:14b
#
# Example B — Anthropic, a different PUBLIC option (NOT sovereign). If set, Daalu
# can use it for text generation. WARNING: data leaves your network — prompts are
# sent to Anthropic. Leave empty to stay fully local. To enable, set BOTH the key
# and a model id (one of Anthropic's current model ids).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# ── Webhook ingest (optional) ───────────────────────────────────────────────
# Shared secret that Alertmanager / PagerDuty / custom webhooks send in the
# `X-Daalu-Key` header to POST events at /api/v1/events. Empty = ingest open
# only while LOCAL_NO_AUTH is on. Generate with: openssl rand -hex 32
INGEST_API_KEY=

# ── Observability / Prometheus (optional) ───────────────────────────────────
# Base URL of the Prometheus the agent queries for the GPU / AI-factory metrics
# views and for metric lookups during alert triage. Empty disables those views
# gracefully ("metrics unavailable"). In-cluster form:
#   http://<prometheus-service>.<namespace>.svc.cluster.local:9090
# From the compose stack against a NodePort Prometheus on the host:
#   http://host.docker.internal:30090
PROMETHEUS_BASE_URL=

# ── Cluster the agent operates on (optional) ────────────────────────────────
# The kubectl tools use this kubeconfig. In docker-compose we mount your
# ~/.kube/config read-only into the api+worker containers at this path.
KUBECONFIG=/home/daalu/.kube/config

# ── Briefing schedule (optional) ────────────────────────────────────────────
# Cron for the daily AI infra briefing (UTC). Default: 06:30 every day.
DAILY_BRIEFING_CRON=30 6 * * *

# ── Frontend ────────────────────────────────────────────────────────────────
# Where the browser reaches the API. Used by the Next.js UI at build/run time.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
